<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<OfficeApp
 xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
 xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
 xsi:type="TaskPaneApp">

  <!-- BASIC INFO -->

  <Id>99887766-5544-3322-1100-aabbccddeeff</Id>

  <Version>1.0.0.0</Version>

  <ProviderName>Divy.AI</ProviderName>

  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="Divy.AI"/>

  <Description DefaultValue="Natural language Excel automation powered by Gemini AI"/>

  <SupportUrl DefaultValue="https://d-divyansh.github.io/Excel.ai/"/>

  <!-- APP DOMAIN -->

  <AppDomains>
    <AppDomain>https://d-divyansh.github.io</AppDomain>
    <AppDomain>https://generativelanguage.googleapis.com</AppDomain>
  </AppDomains>

  <!-- EXCEL HOST -->

  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>

  <!-- TASKPANE -->

  <DefaultSettings>
    <SourceLocation DefaultValue="https://d-divyansh.github.io/Excel.ai/taskpane.html"/>
  </DefaultSettings>

  <!-- PERMISSIONS -->

  <Permissions>ReadWriteDocument</Permissions>

  <!-- MODERN RIBBON UI -->

  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
    xsi:type="VersionOverridesV1_0">

    <Hosts>

      <Host xsi:type="Workbook">

        <DesktopFormFactor>

          <GetStarted>

            <Title resid="GetStarted.Title"/>

            <Description resid="GetStarted.Description"/>

            <LearnMoreUrl resid="LearnMoreUrl"/>

          </GetStarted>

          <FunctionFile resid="Taskpane.Url"/>

          <ExtensionPoint xsi:type="PrimaryCommandSurface">

            <OfficeTab id="TabHome">

              <Group id="DivyAI.Group">

                <Label resid="Group.Label"/>

                <Control xsi:type="Button" id="DivyAI.Button">

                  <Label resid="Button.Label"/>

                  <Supertip>

                    <Title resid="Button.Label"/>

                    <Description resid="Button.Tooltip"/>

                  </Supertip>

                  <Icon>

                    <bt:Image size="16" resid="Icon.16"/>

                    <bt:Image size="32" resid="Icon.32"/>

                    <bt:Image size="80" resid="Icon.80"/>

                  </Icon>

                  <Action xsi:type="ShowTaskpane">

                    <TaskpaneId>DivyAI</TaskpaneId>

                    <SourceLocation resid="Taskpane.Url"/>

                  </Action>

                </Control>

              </Group>

            </OfficeTab>

          </ExtensionPoint>

        </DesktopFormFactor>

      </Host>

    </Hosts>

    <!-- RESOURCES -->

    <Resources>

      <!-- ICONS -->

      <bt:Images>

        <bt:Image
          id="Icon.16"
          DefaultValue="https://d-divyansh.github.io/Excel.ai/icon-16.png"/>

        <bt:Image
          id="Icon.32"
          DefaultValue="https://d-divyansh.github.io/Excel.ai/icon-32.png"/>

        <bt:Image
          id="Icon.80"
          DefaultValue="https://d-divyansh.github.io/Excel.ai/icon-80.png"/>

      </bt:Images>

      <!-- URLS -->

      <bt:Urls>

        <bt:Url
          id="LearnMoreUrl"
          DefaultValue="https://d-divyansh.github.io/Excel.ai/"/>

        <bt:Url
          id="Taskpane.Url"
          DefaultValue="https://d-divyansh.github.io/Excel.ai/taskpane.html"/>

      </bt:Urls>

      <!-- SHORT STRINGS -->

      <bt:ShortStrings>

        <bt:String
          id="GetStarted.Title"
          DefaultValue="Divy.AI"/>

        <bt:String
          id="Group.Label"
          DefaultValue="Divy.AI"/>

        <bt:String
          id="Button.Label"
          DefaultValue="Open Divy.AI"/>

      </bt:ShortStrings>

      <!-- LONG STRINGS -->

      <bt:LongStrings>

        <bt:String
          id="GetStarted.Description"
          DefaultValue="AI-powered Excel assistant"/>

        <bt:String
          id="Button.Tooltip"
          DefaultValue="Launch Divy.AI Gemini Excel Assistant"/>

      </bt:LongStrings>

    </Resources>

  </VersionOverrides>

</OfficeApp>
